{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "TINA_TOKEN",
        "NEXT_PUBLIC_TINA_CLIENT_ID",
        "TINA_BRANCH",
        "GITHUB_BRANCH",
        "HEAD",
        "VERCEL",
        "VERCEL_GIT_COMMIT_REF"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
